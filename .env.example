# --- Telegram ---
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# --- Anthropic (Claude) ---
# Optional. Required only for /api/analyze.
ANTHROPIC_API_KEY=

# --- BingX ---
# Public market data endpoints do not require keys. Keep these for future private methods.
BINGX_API_KEY=
BINGX_API_SECRET=
BINGX_BASE_URL=https://open-api.bingx.com

# --- Coinglass ---
# Optional. Without this key /api/liquidations returns a zero-valued mock shape.
COINGLASS_API_KEY=

# --- Frontend (Mini App) ---
# Telegram requires HTTPS for WebApp buttons. Use an HTTPS tunnel for local development.
WEBAPP_URL=https://your-domain.example.com

# --- Server ---
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
